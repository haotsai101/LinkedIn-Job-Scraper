# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.
#
# First-time setup:
#   playwright install chromium

# Required: OpenAI-compatible API credentials
LLM_API=your-api-key-here
LLM_URL=https://integrate.api.nvidia.com/v1
LLM_MODEL=qwen/qwen3-coder-480b-a35b-instruct

# Optional: separate model/endpoint just for the browser agent (defaults to LLM_* values above)
# BROWSER_LLM_API=your-browser-api-key-here
# BROWSER_LLM_URL=https://integrate.api.nvidia.com/v1
# BROWSER_LLM_MODEL=meta/llama-3.3-70b-instruct
# BROWSER_LLM_FALLBACK_MODEL=meta/llama-3.3-70b-instruct  # switched to after 2 consecutive timeouts (circuit-breaker)

# Optional: separate model/endpoint just for the job classifier (default: same as LLM_*)
# Fast small models work great here (llama-3.1-8b, gemma-3-4b, etc.)
# CLASSIFIER_LLM_API=your-api-key-here
# CLASSIFIER_LLM_URL=https://integrate.api.nvidia.com/v1
# CLASSIFIER_LLM_MODEL=meta/llama-3.1-8b-instruct

# Gmail notification (optional — skipped if not set)
# To generate an App Password: Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Max applications per autonomous session (default: 10)
MAX_AUTO_APPLY=10
